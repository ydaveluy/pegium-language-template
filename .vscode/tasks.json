{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure MyDsl",
            "type": "shell",
            "command": "cmake",
            "args": ["-S", ".", "-B", "build"],
            "problemMatcher": []
        },
        {
            "label": "Build MyDsl",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "-j"],
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": ["Configure MyDsl"],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Test MyDsl",
            "type": "shell",
            "command": "ctest",
            "args": ["--test-dir", "build", "--output-on-failure"],
            "group": { "kind": "test", "isDefault": true },
            "dependsOn": ["Build MyDsl"],
            "problemMatcher": []
        }
    ]
}
